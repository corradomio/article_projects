{
    "#pc": {
        "class": "castle.algorithms.PC",
        "variant": "original",
        "alpha": 0.05,
        "ci_test": "fisherz",
        "priori_knowledge": null
    },
    "#ges": {
        "class": "castle.algorithms.GES",
        "criterion": "bic",
        "method": "scatter",
        "k": 0.001,
        "N": 10
    },
    "#icalingam": {
        "class": "castle.algorithms.ICALiNGAM",
        "random_state": null,
        "max_iter": 1000,
        "thresh": 0.3
    },
    "#directlingam": {
        "class": "castle.algorithms.DirectLiNGAM",
        "prior_knowledge": null,
        "measure": "pwling",
        "thresh": 0
    },
    "#notears": {
        "class": "castle.algorithms.Notears",
        "lambda1": 0.1,
        "loss_type": "l2",
        "max_iter": 100,
        "h_tol": 1e-8,
        "rho_max": 1e+16,
        "w_threshold": 0.3
    },
    "#notearslowrank": {
        "#comment": ["extended version to pass 'rank' (used in 'learn') in configuration"],
        "class": "castlex.algorithms.NotearsLowRank",
        "w_init": null,
        "max_iter": 15,
        "h_tol": 1e-6,
        "rho_max": 1e+20,
        "w_threshold": 0.3,
        "rank": 3
    },

    "#gae": {
        "#comment": {
            "suspended": {
                "activation_": "torch.nn.LeakyReLU(0.05)"
            }
        },
        "class": "castle.algorithms.GAE",
        "input_dim": 1,
        "hidden_layers": 1,
        "hidden_dim": 4,
        "epochs": 10,
        "update_freq": 10000,
        "init_iter": 3,
        "lr": 1e-3,
        "alpha": 0.0,
        "beta": 2.0,
        "init_rho": 1.0,
        "rho_thresh": 1e30,
        "gamma": 0.25,
        "penalty_lambda": 0.0,
        "h_thresh": 1e-8,
        "graph_thresh": 0.3,
        "early_stopping": false,
        "early_stopping_thresh": 1.0,
        "seed": 1230,
        "device_type": "gpu",
        "device_ids": "0"
    },
    "#golem": {
        "#comment": ["slow"],
        "class": "castle.algorithms.GOLEM",
        "B_init": null,
        "lambda_1": 0.02,
        "lambda_2": 5.0,
        "equal_variances": true,
        "learning_rate": 1e-3,
        "num_iter": 100000,
        "checkpoint_iter": 5000,
        "seed": 1,
        "graph_thres": 0.3,
        "device_type": "gpu",
        "device_ids": 0
    },
    "#notearsnonlinear": {
        "class": "castle.algorithms.NotearsNonlinear",
        "lambda1": 0.01,
        "lambda2": 0.01,
        "max_iter": 100,
        "h_tol": 1e-8,
        "rho_max": 1e+16,
        "w_threshold": 0.3,
        "hidden_layers": [10, 1],
        "expansions": 10,
        "bias": true,
        "#model_types": ["mlp", "sob"],
        "model_type": "mlp",
        "device_type": "gpu",
        "device_ids": 0
    },

    "#--very_slow--": {

    },

    "#anmnonlinear": {
        "#comment": ["very slow"],
        "class": "castle.algorithms.ANMNonlinear",
        "alpha": 0.05
    },

    "#dag_gnn": {
        "#comment": ["very slow"],
        "class": "castle.algorithms.DAG_GNN",
        "encoder_type": "mlp",
        "decoder_type": "mlp",
        "encoder_hidden": 64,
        "latent_dim": null,
        "decoder_hidden": 64,
        "encoder_dropout": 0.0,
        "decoder_dropout": 0.0,
        "epochs": 300,
        "k_max_iter": 100,
        "tau_a": 0.0,
        "batch_size": 100,
        "lr": 1e-3,
        "lr_decay": 200,
        "gamma": 1.0,
        "init_lambda_a": 0.0,
        "init_c_a": 1.0,
        "c_a_thresh": 1e20,
        "eta": 10,
        "multiply_h": 0.25,
        "h_tolerance": 1e-8,
        "use_a_connect_loss": false,
        "use_a_positiver_loss": false,
        "graph_threshold": 0.3,
        "optimizer": "adam",
        "seed": 42,
        "device_type": "gpu",
        "device_ids": 0
    },
    "#grandag": {
        "#comment": ["skipped: 'input_dim' in castle GranDAG is delegated to 'learn()"],
